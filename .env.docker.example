# Скопируй в .env перед запуском: cp .env.docker.example .env

# Telegram Bot
VITE_BOT_TOKEN=your_bot_token_here
VITE_ADMIN_CHAT_ID=your_chat_id_here

# URL Mini App — твой домен с HTTPS (обязательно для Telegram)
# Если используешь Caddy — https://твой-домен.com/
# Если nginx/другой прокси — укажи свой URL
WEBAPP_URL=https://example.com/
