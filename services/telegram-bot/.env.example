# Токен бота от @BotFather
BOT_TOKEN=your_bot_token_here

# ID чата администратора (куда приходят заказы)
ADMIN_CHAT_ID=your_chat_id_here

# URL Mini App (кнопка «Открыть меню»)
WEBAPP_URL=https://china-menu.vercel.app/

# Публичный URL бота для webhook (обязательно для продакшена)
# Пример: https://bot.yourdomain.com
WEBHOOK_DOMAIN=

# Порт (по умолчанию 3001)
PORT=3001
