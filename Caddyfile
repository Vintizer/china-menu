# Пример для Caddy с автоматическим HTTPS.
# Замени example.com на свой домен. Caddy сам получит сертификат от Let's Encrypt.
#
# Раскомментируй сервис caddy в docker-compose.yml и запусти:
#   docker compose up -d
#
# Убедись, что порты 80 и 443 открыты и домен указывает на IP сервера.

example.com {
    reverse_proxy app:3000
}

# Webhook для Telegram-бота. Замени bot.example.com на свой поддомен.
# WEBHOOK_DOMAIN=https://bot.example.com
bot.example.com {
    reverse_proxy telegram-bot:3001
}
